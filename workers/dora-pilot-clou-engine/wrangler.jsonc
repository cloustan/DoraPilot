{
    "name": "dora-pilot-cloud-engine",
    "main": "src/index.js",
    "compatibility_date": "2026-06-01",
    "ai": {
        "binding": "AI"
    },
    "routes": [
        {
            "pattern": "ai.api.pilot.dora.ai-engine-v1.cloustan.org",
            "custom_domain": true
        }
    ],
    // Zero data retention posture: no request/response logging persisted.
    "observability": {
        "enabled": false
    }
}
